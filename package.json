    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "i18next": "^26.3.4",
    "i18next-resources-to-backend": "^1.2.1",
    "intl-messageformat": "^11.2.9",
    "lenis": "^1.3.25",
    "lodash": "^4.18.1",
    "lucide-react": "^1.22.0",
