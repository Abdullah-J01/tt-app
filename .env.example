# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Dev/demo mode: "true" = localStorage likes/saves; "false" = persistence via
# TT API seams. Does not affect login — credentials sign-in always verifies a
# real hashed password (src/lib/auth.ts).
NEXT_PUBLIC_DEV_MODE=true

# TaskuTark (TT) backend — the app's data source (content, feed, search…).
# Server-side base URL used by src/lib/tt-api.ts. See docs/TT_API_ENDPOINTS.md.
TT_API_BASE_URL="https://api.taskutark.ee"
# Optional auth for the TT API (API key / service token) — confirm with TT.
TT_API_KEY=
# Force mock data even when TT_API_BASE_URL is set (handy for local UI work).
USE_MOCK_DATA=0

# Auth (NextAuth / Auth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Admin CMS access — comma-separated email allowlist checked in src/lib/roles.ts.
# There is no separate admin login: an allowlisted email signs in through the
# same form as everyone else, and the role is derived server-side on each request.
#
# Allowlisted addresses CANNOT self-register (/api/auth/signup rejects them) —
# otherwise anyone could claim the admin email on a fresh deploy. Seed the
# account out-of-band instead:  npm run seed:admin -- you@example.com
#
# Set this to a real address you control. Left blank, nobody is an admin and
# /admin 404s for everyone.
# TODO(team): replaced by TT's role claim once TT auth is confirmed.
ADMIN_EMAILS=

# Supabase — identity backend for auth ONLY (login + sign-up). Supabase owns no
# app data here; NextAuth still issues the session and ADMIN_EMAILS still drives
# roles. Used by src/lib/supabase/admin.ts (server-only). All three are required;
# the app fails at startup without them. Find them in the Supabase dashboard:
# Project Settings → API. Keep the service-role key SECRET — never NEXT_PUBLIC_.
#   Project URL:        Settings → API → Project URL
#   anon public key:    Settings → API → Project API keys → anon / public
#   service_role key:   Settings → API → Project API keys → service_role (secret)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (optional for MVP; enable in src/lib/auth.ts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (payments / premium) — test keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
