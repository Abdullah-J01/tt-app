# This stack pins current majors (Next 16, React 19, Prisma 7). Some libraries'
# peer ranges lag a release behind (e.g. next-auth v4 vs Next 16), which would
# otherwise make a clean `npm install` fail with ERESOLVE. Allow it for now.
# Revisit once all deps declare support (or move to Auth.js v5).
legacy-peer-deps=true
